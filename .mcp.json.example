{
  "mcpServers": {
    "penpot": {
      "type": "stdio",
      "command": "uvx",
      "args": ["penpot-mcp"],
      "env": {
        "PENPOT_API_URL": "http://localhost:9001/api",
        "PENPOT_USERNAME": "<PENPOT_EMAIL from design/.env>",
        "PENPOT_PASSWORD": "<PENPOT_PASSWORD from design/.env>"
      }
    }
  }
}
