{
  "meta": {
    "name": "cords CCG — Location card, layout 'Gate', V2 'Modern Trek'",
    "example": "The Great Wall (ALPHA-1 · L09, epic, blocked N/S, ROTATE action)",
    "note": "Only location-specific values. Palette, fonts (Space Grotesk / JetBrains Mono), gold coin gradient, and rarity gems are identical to card-spec.json (unit card). All boxes below measured from the live DOM at 1:1 — text baselines accurate to ±1px.",
    "sharedWithUnitCard": "colors, fonts, cost/VP coin gradient (#ffe9a8 → #f4c24a 55% → #a3761a, focal 35% 30%, border 2px #8a6522, inner ring 3px #ffe9a8 @33%), footer type styling, rarity gems/colors"
  },

  "canvas": { "width": 750, "height": 750, "cardCornerRadius": 14, "background": "#0a1220" },

  "artHatch": {
    "coverage": "full-bleed (entire 750×750, under everything)",
    "lineAngle": "45° from vertical, stripes running top-left → bottom-right ('\\'), matching CSS repeating-linear-gradient(45deg); in SVG use patternTransform=rotate(-45) on a vertical stripe",
    "stripeWidth": 2,
    "period": 16,
    "stripeColor": "#ffffff",
    "stripeOpacity": 0.05,
    "mask": "none — no fade (unlike the unit card's radial-masked grid)",
    "watermark": {
      "glyph": "location-type icon (24×24 line icon, stroke-width 1.6, stroke-linejoin round)",
      "box": { "x": 205, "y": 198, "w": 340, "h": 340 },
      "color": "#7a8aa6", "opacity": 0.16
    },
    "artLabel": {
      "text": "LOCATION ART", "font": "JetBrains Mono", "size": 10, "weight": 400,
      "letterSpacing": "0.3em", "transform": "uppercase", "color": "#7a8aa6", "opacity": 0.7,
      "position": "centered horizontally, top y=412.5 (baseline ≈422.5)"
    }
  },

  "compassEdges": {
    "semantics": {
      "BLOCKED": "solid heavy bar — 14px stroke, color #ff5a4e (edge-blocked red), runs the full side; letter sits on a solid red plate",
      "OPEN": "thin 2px line, color #7a8aa6 @ 40% opacity, with a 140px gate gap centered on the side (gap = ±70 from midpoint); 14px-long perpendicular ticks cap both gap ends; letter floats in the gap, same 40% grey",
      "dataMapping": "loc.edges lists BLOCKED sides; every side NOT listed renders OPEN"
    },
    "geometry": {
      "inset": 9,
      "note": "bar/line centerline sits 9px in from each card edge; strokes are centered on that line (blocked bar spans 2–16px from edge). Card overflow is clipped by the 14px-radius card shape.",
      "N": { "line": { "x1": 9, "y1": 9, "x2": 741, "y2": 9 } },
      "S": { "line": { "x1": 9, "y1": 741, "x2": 741, "y2": 741 } },
      "W": { "line": { "x1": 9, "y1": 9, "x2": 9, "y2": 741 }, "gapY": [305, 445] },
      "E": { "line": { "x1": 741, "y1": 9, "x2": 741, "y2": 741 }, "gapY": [305, 445] }
    },
    "blockedLabelPlate": { "w": 30, "h": 19, "r": 2, "fill": "#ff5a4e", "centeredOnBar": true },
    "letterLabel": {
      "font": "JetBrains Mono", "size": 13, "weight": 700, "letterSpacing": 1, "anchor": "middle",
      "colorOnBlocked": "#0a1220 (card bg, on the red plate)",
      "colorOnOpen": "#7a8aa6 @ 40%",
      "position": "midpoint of the side, baseline = centerline + 4.5"
    }
  },

  "header": {
