# Penpot instance connection
# Host port for the local Penpot frontend (used by both docker-compose and Python scripts)
PENPOT_PORT=9011
# Optional: override the full URL (e.g. for a remote Penpot instance). If unset, defaults to http://localhost:${PENPOT_PORT}
#PENPOT_URL=
PENPOT_EMAIL=your-email@example.com
PENPOT_PASSWORD=your-password-here

# REQUIRED — the backend crash-loops on startup if this is empty.
# Generate one:  python3 -c "import secrets; print(secrets.token_urlsafe(64))"
# Or just run:   python3 design/preflight.py --fix   (generates it and starts the stack,
#                                                      once email/password above are set)
PENPOT_SECRET_KEY=

# PENPOT_FILE_ID — created and written back automatically on the renderer's
# first run (moderntrek-template.py) if left blank; or run `preflight.py --fix`.
PENPOT_FILE_ID=
# PENPOT_PAGE_ID — leave blank; the renderer derives it at runtime from the
# file's first page. It is not written back to this file.
PENPOT_PAGE_ID=
