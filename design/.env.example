# Penpot instance connection
# Host port for the local Penpot frontend (used by both docker-compose and Python scripts)
PENPOT_PORT=9011
# Optional: override the full URL (e.g. for a remote Penpot instance). If unset, defaults to http://localhost:${PENPOT_PORT}
#PENPOT_URL=
PENPOT_EMAIL=your-email@example.com
PENPOT_PASSWORD=your-password-here

# Secret key for Penpot (generate with: python3 -c "import secrets; print(secrets.token_urlsafe(64))")
PENPOT_SECRET_KEY=

# File/page IDs (set after first run of setup-template.py)
PENPOT_FILE_ID=
PENPOT_PAGE_ID=
