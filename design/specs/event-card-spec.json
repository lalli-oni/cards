    "passive": { "color": "#7a8aa6 (mute — no accent2 in trek)", "topEdge": "solid 12px bar", "badge": "solid fill + label 'PASSIVE · N TURNS' + duration pips (10px circles, gap 5, glow 0 0 6px col@40%)" },
    "trap": { "color": "#ff6b6b (hazard)", "topEdge": "hazard stripes 12px on/12px off at 45°, height 12, opacity .9", "badge": "outlined 2px, transparent fill, text in hazard color + 40×8 hazard swatch (8/8 stripes, r2, opacity .8) to the right" }
  },

