      "rarity": { "text": "◆ EPIC", "x": 59, "baseline": 698.5, "font": "JetBrains Mono", "size": 9, "weight": 700, "letterSpacing": "0.22em", "color": "#c8f562 (rarity accent)", "note": "same as unit footer" },
      "setId": { "text": "MISSION // ALPHA-1 · L09", "rightAlignedTo": 691, "baseline": 698.5, "font": "JetBrains Mono", "size": 9, "weight": 400, "letterSpacing": "0.22em", "color": "#7a8aa6", "note": "prefix is 'MISSION' for mission locations, 'LOCATION' otherwise; matches unit footer style. L## is the location set number" }
    }
  },

